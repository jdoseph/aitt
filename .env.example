# AI Infra Tracker — configuration
# Copy to `.env` and edit. All keys are optional; defaults live in src/core/config.py.
# Every key is prefixed AITT_.

# --- paths (relative paths resolve from the project root) ---
# AITT_DATA_DIR=data
# AITT_DB_PATH=data/tracker.db
# AITT_WATCHLIST_PATH=src/core/watchlist.yaml

# --- data layer ---
# AITT_HISTORY_BARS=200
# AITT_DATA_SOURCE=yfinance
# AITT_FETCH_MAX_RETRIES=3
# AITT_FETCH_RETRY_BACKOFF_SEC=2.0

# --- Strategy 1: EMA pullback (percent thresholds) ---
# AITT_EMA_EXTENDED_PCT=8.0
# AITT_EMA_APPROACHING_9_PCT=2.0
# AITT_EMA_APPROACHING_21_PCT=3.0
# AITT_USE_TREND_FILTER=false          # only alert when price > 50 EMA (Q5)
# AITT_EMA_REQUIRE_VOLUME=false        # require above-avg volume on touch (Q6)

# --- Strategy 2: consolidation breakout ---
# AITT_CONSOLIDATION_RANGE_PCT=8.0
# AITT_CONSOLIDATION_MIN_DAYS=10
# AITT_BREAKOUT_VOLUME_MULT=1.5

# --- Strategy 3: ATH pullback (percent below ATH) ---
# AITT_ATH_AT_PCT=1.0
# AITT_ATH_ENTRY_LOW_PCT=5.0
# AITT_ATH_ENTRY_HIGH_PCT=10.0
# AITT_ATH_DEEP_PCT=20.0
# AITT_ATH_FRESHNESS_DAYS=30

# --- Strategy 4: IPO base ---
# AITT_IPO_MAX_HISTORY_DAYS=60
# AITT_IPO_INITIAL_HIGH_DAYS=5
# AITT_IPO_FRESH_DAYS=5
# AITT_IPO_FAILED_DRAWDOWN_PCT=25.0

# --- indicators ---
# AITT_VOLUME_AVG_WINDOW=20

# --- alerts ---
# AITT_MIN_CONFIDENCE_STARS=1          # 1 fires all signals; raise to reduce noise
# AITT_ALERT_DESKTOP=true
# AITT_ALERT_CONSOLE=true

# --- scheduler (daily-close cadence) ---
# AITT_MARKET_TZ=America/New_York
# AITT_EOD_EVAL_HHMM=16:15             # local-to-market time to run the daily eval

# --- logging ---
# AITT_LOG_LEVEL=INFO
